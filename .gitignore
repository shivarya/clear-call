# Server secrets
server/.env
server/.env.production
server/php_errors.log
*service-account*.json
*firebase-adminsdk*.json

# Composer deps — installed on the host via `composer install` at deploy time
server/vendor/
server/composer.lock

# Mobile (P1+)
mobile/app/google-services.json
# ML assets (large binaries; fetch with mobile/scripts/fetch-ml-assets.ps1)
mobile/app/libs/*.aar
mobile/app/src/main/assets/models/
# IDE (VSCode Java ext) build output
mobile/app/bin/
mobile/.gradle/
mobile/build/
mobile/app/build/
mobile/local.properties
mobile/keystore.properties
*.keystore
!debug.keystore
