# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=clear_call
DB_USER=root
DB_PASS=

# Session JWTs (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRES_IN=2592000

# Google Sign-In — WEB client ID (the audience on ID tokens from the Android app)
GOOGLE_CLIENT_ID=
# Optional extra audiences, comma-separated (native client IDs)
GOOGLE_ALLOWED_AUDIENCES=

# Dev login backdoor (POST /auth/login {as:1|2}) — local only, NEVER true in prod
ALLOW_DEV_LOGIN=false

# LiveKit Cloud project (cloud.livekit.io -> project settings -> Keys)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# FCM v1 — Android ring pushes (Firebase console -> settings -> Service accounts -> generate key)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_PATH=/home/<cpanel-user>/secrets/clear-call-fcm.json

# APNs VoIP — iOS ring pushes (P4.5+). Leave unset until an Apple Developer account exists;
# sends are skipped gracefully meanwhile. .p8 auth key from developer.apple.com -> Keys.
APNS_KEY_PATH=/home/<cpanel-user>/secrets/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=dev.shivarya.clearcall
APNS_ENV=sandbox

RING_TIMEOUT_SECONDS=45
